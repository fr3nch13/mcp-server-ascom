# ASCOM MCP Server Configuration
# Copy to .env to customize settings

# MCP server settings
MCP_SERVER_NAME="ascom"

# Logging
LOG_LEVEL=INFO

# OAuth 2.0 Security (disabled by default for easy adoption)
# Uncomment and configure to enable authentication
# ASCOM_MCP_OAUTH_ENABLED=true
# ASCOM_MCP_OAUTH_ISSUER=https://auth.example.com
# ASCOM_MCP_OAUTH_AUDIENCE=ascom-mcp-server
# ASCOM_MCP_OAUTH_CLIENT_ID=your-client-id

# Security settings
# ASCOM_MCP_REQUIRE_HTTPS=true
# ASCOM_MCP_TOKEN_EXPIRY_HOURS=24

# CORS settings (comma-separated origins or * for all)
# Default allows all origins for easy testing
ASCOM_MCP_ALLOWED_ORIGINS=*

# Rate limiting (optional)
# ASCOM_MCP_RATE_LIMIT=false

# Discovery settings
ASCOM_DISCOVERY_TIMEOUT=10

# MCP features (enable when spec supports them)
# ASCOM_MCP_STRUCTURED_CONTENT=true
# ASCOM_MCP_ELICITATION=true

# Environment for Real Seestar Testing

# Direct device configuration (v0.4.0 feature)
# Format: name:host:port:description
ASCOM_DIRECT_DEVICES="telescope_1:seestar.local:5555:Seestar S50,telescope_2:192.168.1.100:5555:Seestar S50 Direct"

# Known devices to check if not found
ASCOM_KNOWN_DEVICES="seestar.local:5555:seestar_alp"

# No simulator devices for real hardware testing
# ASCOM_SIMULATOR_DEVICES=